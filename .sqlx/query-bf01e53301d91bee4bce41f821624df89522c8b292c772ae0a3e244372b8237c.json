  "query": "SELECT \n            e.id as \"id!\",\n            e.title as \"title!\",\n            e.author_name,\n            e.price as \"price!\",\n            e.cover as \"cover!\",\n            e.description,\n            f.name as \"format!\",\n            e.language,\n            e.page_count,\n            e.translator,\n            e.publication_date,\n            e.isbn,\n            e.edition_name\n         FROM editions e\n         INNER JOIN books b ON e.book_id = b.id\n         INNER JOIN formats f ON e.format_id = f.id\n         WHERE b.slug = ?",
