{
  "db_name": "SQLite",
  "query": "SELECT \n            e.id,\n            e.title,\n            COALESCE(e.author_name, a.name) as author,\n            e.price,\n            e.cover,\n            a.slug || '/' || e.slug as slug\n         FROM editions e\n         INNER JOIN books b ON e.book_id = b.id\n         INNER JOIN authors a ON b.author_id = a.id",
