<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
            font-size: 15px;
            line-height: 1.5;
            padding: 48px 24px;
            max-width: 520px;
            margin: 0 auto;
        }

        h1 {
            font-size: 20px;
            font-weight: 600;
            margin-bottom: 32px;
        }

        .book {
            margin-bottom: 24px;
        }

        .book-title {
            font-weight: 600;
            margin-bottom: 1px;
        }

        .book-author {
            font-size: 13px;
            opacity: 0.5;
            margin-bottom: 8px;
        }

        .download-links {
            font-size: 13px;
        }

        .download-links a {
            color: inherit;
            text-decoration: underline;
            margin-right: 12px;
            opacity: 0.7;
        }

        .download-links a:hover {
            opacity: 1;
        }

        .no-files {
            font-size: 13px;
            opacity: 0.4;
            font-style: italic;
        }

        .footer {
            margin-top: 48px;
            font-size: 13px;
            opacity: 0.35;
        }
    </style>
</head>
<body>

    <h1>Your downloads are ready. Thank you for your custom.</h1>

    {% if books | length == 0 %}
        <p class="no-files">No downloadable items found for this order. If you think this is a mistake, reply to this email.</p>
    {% else %}
        {% for book in books %}
            {% for edition in book.editions %}
                <div class="book">
                    <div class="book-title">{{ edition.title }}</div>
                    <div class="book-author">{{ edition.author_name }}</div>
                    {% if edition.files and edition.files | length > 0 %}
                        <div class="download-links">
                            {% for file in edition.files %}
                                <a href="{{ base_url }}{{ file.path }}">{{ file.format | default(value="Download") | upper }}</a>
                            {% endfor %}
                        </div>
                    {% else %}
                        <p class="no-files">No files available.</p>
                    {% endif %}
                </div>
            {% endfor %}
        {% endfor %}
    {% endif %}

    <div class="footer">Questions? Reply to this email and we’ll help. &nbsp;·&nbsp; Order #{{ order_id }}</div>

</body>
</html>
