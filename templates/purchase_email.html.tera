<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,600;1,400&family=DM+Sans:wght@400;500&display=swap');

        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'DM Sans', sans-serif;
            background-color: #f0ebe3;
            color: #2c2417;
            padding: 32px 16px;
        }

        .container {
            max-width: 560px;
            margin: 0 auto;
            background: #faf8f4;
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 4px 24px rgba(44, 36, 23, 0.10);
        }

        .header {
            background: #2c2417;
            padding: 32px 36px 28px;
            color: #f0ebe3;
        }

        .header h1 {
            font-family: 'Lora', serif;
            font-size: 22px;
            font-weight: 600;
            letter-spacing: -0.3px;
            margin-bottom: 4px;
        }

        .header .order-ref {
            font-size: 13px;
            color: #a89880;
            letter-spacing: 0.3px;
        }

        .body {
            padding: 28px 36px 36px;
        }

        .intro {
            font-size: 14px;
            color: #6b5d4f;
            margin-bottom: 24px;
        }

        .book {
            padding: 18px 0;
            border-bottom: 1px solid #e8e1d6;
        }

        .book:last-child {
            border-bottom: none;
        }

        .book-title {
            font-family: 'Lora', serif;
            font-size: 15px;
            font-weight: 600;
            color: #2c2417;
            margin-bottom: 2px;
            line-height: 1.3;
        }

        .book-author {
            font-size: 12px;
            color: #9e8c78;
            margin-bottom: 12px;
        }

        .download-links {
            display: flex;
            flex-wrap: wrap;
            gap: 6px;
        }

        .download-link {
            display: inline-block;
            padding: 5px 12px;
            background: #2c2417;
            color: #f0ebe3;
            text-decoration: none;
            border-radius: 4px;
            font-size: 11px;
            font-weight: 500;
            letter-spacing: 0.6px;
            text-transform: uppercase;
            transition: background 0.15s;
        }

        .download-link:hover {
            background: #4a3d2e;
        }

        .no-files {
            font-size: 13px;
            color: #9e8c78;
            font-style: italic;
        }

        .empty-state {
            text-align: center;
            padding: 40px 24px;
            color: #9e8c78;
            font-size: 14px;
        }

        .footer {
            padding: 20px 36px;
            background: #f0ebe3;
            font-size: 12px;
            color: #9e8c78;
            text-align: center;
            border-top: 1px solid #e0d8cc;
        }

        @media (max-width: 480px) {
            .header, .body { padding-left: 20px; padding-right: 20px; }
            .footer { padding-left: 20px; padding-right: 20px; }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>Thanks for your custom.</h1>
            <p class="order-ref">Order #{{ order_id }}</p>
        </div>

        <div class="body">
            <p class="intro">Your downloads are ready below.</p>

            {% if books | length == 0 %}
                <div class="empty-state">
                    No downloadable items found for this order. If you believe this is an error, please reply to this email.
                </div>
            {% else %}
                {% for book in books %}
                    {% for edition in book.editions %}
                        <div class="book">
                            <div class="book-title">{{ edition.title }}</div>
                            <div class="book-author">{{ edition.author_name }}</div>

                            {% if edition.files and edition.files | length > 0 %}
                                <div class="download-links">
                                    {% for file in edition.files %}
                                        <a href="{{ base_url }}{{ file.path }}" class="download-link">
                                            {{ file.format | default(value="Download") | upper }}
                                        </a>
                                    {% endfor %}
                                </div>
                            {% else %}
                                <p class="no-files">No files available.</p>
                            {% endif %}
                        </div>
                    {% endfor %}
                {% endfor %}
            {% endif %}
        </div>

        <div class="footer">
            Questions? Reply to this email and we'll help.
        </div>
    </div>
</body>
</html>
